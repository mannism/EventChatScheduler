{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "parserOpts": {
          "headerPattern": "^(?:\\[v[\\d.]+\\]\\s+)?(feat|fix|feature|bugfix|chore|refactor|docs|style|test|perf|ci|build|revert)(?:\\(.+\\))?[!]?[:\\s]+(.+)$",
          "headerCorrespondence": ["type", "subject"]
        },
        "releaseRules": [
          { "type": "feat",     "release": "minor" },
          { "type": "feature",  "release": "minor" },
          { "type": "fix",      "release": "patch" },
          { "type": "bugfix",   "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "perf",     "release": "patch" },
          { "type": "chore",    "release": false },
          { "type": "docs",     "release": false },
          { "type": "style",    "release": false },
          { "type": "test",     "release": false },
          { "type": "ci",       "release": false },
          { "type": "build",    "release": false }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "parserOpts": {
          "headerPattern": "^(?:\\[v[\\d.]+\\]\\s+)?(feat|fix|feature|bugfix|chore|refactor|docs|style|test|perf|ci|build|revert)(?:\\(.+\\))?[!]?[:\\s]+(.+)$",
          "headerCorrespondence": ["type", "subject"]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/# AI Conference Assistant v[0-9]*\\.[0-9]*\\.[0-9]*/# AI Conference Assistant v${nextRelease.version}/' README.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "CHANGELOG.md", "README.md"],
        "message": "[skip ci] chore: release v${nextRelease.version}"
      }
    ],
    "@semantic-release/github"
  ]
}
